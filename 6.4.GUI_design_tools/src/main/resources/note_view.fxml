<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="Controller.NoteController"
      xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      spacing="10.0" prefHeight="500.0" prefWidth="600.0">

    <children>
        <Label text="Title:" style="-fx-font-weight: bold;" />
        <TextField fx:id="titleField" promptText="Enter note title..." prefWidth="500.0" />

        <Label text="Content:" style="-fx-font-weight: bold;" />
        <TextArea fx:id="contentArea" promptText="Enter note content..."
                  prefHeight="100.0" prefWidth="500.0" wrapText="true" />

        <HBox spacing="10.0">
            <Button fx:id="addButton" text="Add Note" onAction="#handleAddNote" prefWidth="100.0" />
            <Button fx:id="deleteButton" text="Delete Selected" onAction="#handleDeleteNote"
                    prefWidth="120.0" disable="true" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>

        <Separator />
        <Label text="Notes List:" style="-fx-font-weight: bold;" />
        <ListView fx:id="notesListView" prefHeight="250.0" prefWidth="550.0" />
    </children>

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>

</VBox>
